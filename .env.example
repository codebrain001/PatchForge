# ─────────────────────────────────────────────────
# PatchForge v1.0  —  Environment Configuration
# ─────────────────────────────────────────────────

# --- LLM Provider ---
# "gemini" = Gemini only | "openai" = OpenAI only | "auto" = try Gemini, fall back to OpenAI
LLM_PROVIDER=auto

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-nano

# --- Vision Models ---
SAM2_MODEL_NAME=facebook/sam2.1-hiera-small
DEPTH_MODEL_NAME=depth-anything/Depth-Anything-V2-Small-hf

# --- Calibration ---
ARUCO_MARKER_SIZE_MM=40.0
DEFAULT_THICKNESS_MM=3.0

# --- Storage (relative to project root) ---
UPLOAD_DIR=app/static/uploads
MASKS_DIR=app/static/masks
MESHES_DIR=app/static/meshes
VIDEOS_DIR=app/static/videos
FRAMES_DIR=app/static/frames

# --- Video Processing ---
VIDEO_MAX_DURATION_SEC=30
VIDEO_SAMPLE_FPS=2.0
VIDEO_MAX_KEYFRAMES=10
VIDEO_FRAME_DIFF_THRESHOLD=25.0

# --- Device ---
# Auto-detected: "cuda" if GPU available, else "cpu"
DEVICE=cuda

# --- Bambu Lab A1 Printer (optional — leave blank to disable) ---
BAMBU_PRINTER_IP=
BAMBU_ACCESS_CODE=
BAMBU_SERIAL=
BAMBU_FILAMENT=PLA
BAMBU_NOZZLE=0.4

# --- Slicer (auto-detected Bambu Studio install) ---
# Set to full path if not auto-detected, e.g.:
# BAMBU_STUDIO_PATH=C:\Program Files\Bambu Studio\bambu-studio.exe
BAMBU_STUDIO_PATH=
AUTO_SLICE=true
